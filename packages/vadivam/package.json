{
  "name": "vadivam",
  "version": "0.0.17",
  "description": "Pixel-perfect, open-source, gorgeous SVG icons for refined interfaces.",
  "license": "MIT",
  "author": "Praveen Juge",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/praveenjuge/vadivam.git",
    "directory": "packages/vadivam"
  },
  "homepage": "https://vadivam.praveenjuge.com",
  "bugs": {
    "url": "https://github.com/praveenjuge/vadivam/issues"
  },
  "keywords": [
    "icons",
    "svg",
    "icon-pack",
    "open-source",
    "vadivam"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js",
      "default": "./dist/manifest.js"
    },
    "./icons/*.svg": "./dist/icons/*.svg",
    "./icons/*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.js",
      "default": "./dist/icons/*.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "vadivam",
  "version": "0.0.30",
  "description": "Pixel-perfect 24px outline SVG icons with tree-shakeable ESM imports and metadata.",
  "license": "MIT",
  "author": "Praveen Juge",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/praveenjuge/vadivam.git",
    "directory": "packages/vadivam"
  },
  "homepage": "https://vadivam.praveenjuge.com",
  "bugs": {
    "url": "https://github.com/praveenjuge/vadivam/issues"
  },
  "keywords": [
    "icons",
    "svg",
    "outline-icons",
    "icon-library",
    "icon-pack",
    "24px",
    "tree-shakeable",
    "open-source",
    "vadivam",
    "javascript"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/font/vadivam.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js",
      "default": "./dist/manifest.js"
    },
    "./icons/*.svg": "./dist/icons/*.svg",
    "./icons/*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.js",
      "default": "./dist/icons/*.js"
    },
    "./strings/*": {
      "types": "./dist/strings/*.d.ts",
      "import": "./dist/strings/*.js",
      "default": "./dist/strings/*.js"
    },
    "./sprite.svg": "./dist/sprite.svg",
    "./font/vadivam.css": "./dist/font/vadivam.css",
    "./font/vadivam.woff2": "./dist/font/vadivam.woff2",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "vadivam",
  "version": "0.0.1",
  "description": "Optimized SVG icons from the Vadivam icon set.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js",
      "default": "./dist/manifest.js"
    },
    "./icons/*.svg": "./dist/icons/*.svg",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  }
}

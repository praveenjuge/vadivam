{
  "name": "vadivam-solid",
  "version": "0.0.20",
  "description": "Pixel-perfect Vadivam icons for Solid.",
  "license": "MIT",
  "author": "Praveen Juge",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/praveenjuge/vadivam.git",
    "directory": "packages/vadivam-solid"
  },
  "homepage": "https://vadivam.praveenjuge.com",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "solid": "./dist/source/index.jsx",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dynamic": {
      "types": "./dist/dynamic.d.ts",
      "solid": "./dist/source/dynamic.jsx",
      "import": "./dist/dynamic.js",
      "default": "./dist/dynamic.js"
    },
    "./dynamicIconImports": {
      "types": "./dist/dynamicIconImports.d.ts",
      "solid": "./dist/source/dynamicIconImports.js",
      "import": "./dist/dynamicIconImports.js",
      "default": "./dist/dynamicIconImports.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "solid": "./dist/source/icons/index.jsx",
      "import": "./dist/icons/index.js",
      "default": "./dist/icons/index.js"
    },
    "./icons/*": {
      "types": "./dist/icons/*.d.ts",
      "solid": "./dist/source/icons/*.jsx",
      "import": "./dist/icons/*.js",
      "default": "./dist/icons/*.js"
    },
    "./*": {
      "types": "./dist/icons/*.d.ts",
      "solid": "./dist/source/icons/*.jsx",
      "import": "./dist/icons/*.js",
      "default": "./dist/icons/*.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "solid-js": ">=1.9 <2"
  },
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "vadivam-react-native",
  "version": "0.0.27",
  "description": "Pixel-perfect 24px outline icons for React Native and Expo, powered by react-native-svg.",
  "license": "MIT",
  "author": "Praveen Juge",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/praveenjuge/vadivam.git",
    "directory": "packages/vadivam-react-native"
  },
  "homepage": "https://vadivam.praveenjuge.com",
  "bugs": {
    "url": "https://github.com/praveenjuge/vadivam/issues"
  },
  "keywords": [
    "icons",
    "svg",
    "outline-icons",
    "icon-library",
    "icon-pack",
    "24px",
    "tree-shakeable",
    "open-source",
    "vadivam",
    "react-native",
    "react-native-svg",
    "expo"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "react-native": "./dist/icons/index.js",
      "import": "./dist/icons/index.js",
      "default": "./dist/icons/index.js"
    },
    "./dynamic": {
      "types": "./dist/dynamic.d.ts",
      "react-native": "./dist/dynamic.js",
      "import": "./dist/dynamic.js",
      "default": "./dist/dynamic.js"
    },
    "./dynamicIconImports": {
      "types": "./dist/dynamicIconImports.d.ts",
      "react-native": "./dist/dynamicIconImports.js",
      "import": "./dist/dynamicIconImports.js",
      "default": "./dist/dynamicIconImports.js"
    },
    "./icons/*": {
      "types": "./dist/icons/*.d.ts",
      "react-native": "./dist/icons/*.js",
      "import": "./dist/icons/*.js",
      "default": "./dist/icons/*.js"
    },
    "./*": {
      "types": "./dist/icons/*.d.ts",
      "react-native": "./dist/icons/*.js",
      "import": "./dist/icons/*.js",
      "default": "./dist/icons/*.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-native": ">=0.71",
    "react-native-svg": ">=12 <16"
  },
  "publishConfig": {
    "access": "public"
  }
}

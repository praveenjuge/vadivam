---
import { icons } from "vadivam";
import BaseLayout from "../layouts/BaseLayout.astro";

const npmIcon = `<svg viewBox="0 0 2500 2500" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><path fill="#c00" d="M0 0h2500v2500H0z"/><path fill="#fff" d="M1241.5 268.5h-973v1962.9h972.9V763.5h495v1467.9h495V268.5z"/></svg>`;
const githubIcon = `<svg viewBox="0 0 1024 1024" fill="none"><path fill="currentColor" fill-rule="evenodd" d="M512 0C229.12 0 0 229.12 0 512c0 226.56 146.56 417.92 350.08 485.76 25.6 4.48 35.2-10.88 35.2-24.32 0-12.16-.64-52.48-.64-95.36-128.64 23.68-161.92-31.36-172.16-60.16-5.76-14.72-30.72-60.16-52.48-72.32-17.92-9.6-43.52-33.28-.64-33.92 40.32-.64 69.12 37.12 78.72 52.48 46.08 77.44 119.68 55.68 149.12 42.24 4.48-33.28 17.92-55.68 32.64-68.48-113.92-12.8-232.96-56.96-232.96-252.8 0-55.68 19.84-101.76 52.48-137.6-5.12-12.8-23.04-65.28 5.12-135.68 0 0 42.88-13.44 140.8 52.48 40.96-11.52 84.48-17.28 128-17.28s87.04 5.76 128 17.28c97.92-66.56 140.8-52.48 140.8-52.48 28.16 70.4 10.24 122.88 5.12 135.68 32.64 35.84 52.48 81.28 52.48 137.6 0 196.48-119.68 240-233.6 252.8 18.56 16 34.56 46.72 34.56 94.72 0 68.48-.64 123.52-.64 140.8 0 13.44 9.6 29.44 35.2 24.32C877.44 929.92 1024 737.92 1024 512 1024 229.12 794.88 0 512 0" clip-rule="evenodd"/></svg>`;
const twitterIcon = `<svg viewBox="0 0 256 209" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid" aria-hidden="true" focusable="false"><path fill="#55acee" d="M256 25.45c-9.42 4.177-19.542 7-30.166 8.27 10.845-6.5 19.172-16.793 23.093-29.057a105.183 105.183 0 0 1-33.351 12.745C205.995 7.201 192.346.822 177.239.822c-29.006 0-52.523 23.516-52.523 52.52 0 4.117.465 8.125 1.36 11.97-43.65-2.191-82.35-23.1-108.255-54.876-4.52 7.757-7.11 16.78-7.11 26.404 0 18.222 9.273 34.297 23.365 43.716a52.312 52.312 0 0 1-23.79-6.57c-.003.22-.003.44-.003.661 0 25.447 18.104 46.675 42.13 51.5a52.592 52.592 0 0 1-23.718.9c6.683 20.866 26.08 36.05 49.062 36.475-17.975 14.086-40.622 22.483-65.228 22.483-4.24 0-8.42-.249-12.529-.734 23.243 14.902 50.85 23.597 80.51 23.597 96.607 0 149.434-80.031 149.434-149.435 0-2.278-.05-4.543-.152-6.795A106.748 106.748 0 0 0 256 25.45"/></svg>`;

const links = [
  {
    href: "https://www.npmjs.com/package/vadivam",
    label: "vadivam",
    icon: npmIcon
  },
  {
    href: "https://www.npmjs.com/package/vadivam-react",
    label: "vadivam-react",
    icon: npmIcon
  },
  {
    href: "https://github.com/praveenjuge/vadivam",
    label: "GitHub",
    icon: githubIcon
  },
  {
    href: "https://github.com/praveenjuge/vadivam/issues",
    label: "Issues",
    icon: githubIcon
  },
  {
    href: "https://github.com/praveenjuge/vadivam/releases",
    label: "Download",
    icon: githubIcon
  },
  {
    href: "https://twitter.com/praveenjuge",
    label: "Twitter",
    icon: twitterIcon
  }
];
---

<BaseLayout
  title="Vadivam - Free, open-source 24px outline SVG and React icons"
  description="Vadivam is a free, open-source icon set. Browse hundreds of pixel-perfect 24px outline icons. Available as raw SVG and React components via npm."
  keywords={["icons", "svg icons", "react icons", "outline icons", "24px icons", "open source icons", "vadivam", "free icons"]}
>
  <nav class="links" aria-label="Project links">
    {
      links.map((link) => (
        <a class="btn" href={link.href} target="_blank" rel="noreferrer">
          {link.icon && <span class="btn-icon" set:html={link.icon} />}
          <span>{link.label}</span>
        </a>
      ))
    }
  </nav>

  <input class="search" id="iconSearch" type="search" placeholder="Search Icons..." aria-label="Search Icons..." />

  <ul class="icon-grid" id="iconGrid">
    {
      icons.map((icon) => (
        <li class="icon-item" data-name={`${icon.name} ${icon.componentName}`} data-svg={icon.svg} data-component={icon.componentName}>
          <a class="icon-link" href={`/icons/${icon.name}/`} aria-label={icon.componentName} title={icon.componentName}>
            <span set:html={icon.svg}></span>
          </a>
        </li>
      ))
    }
  </ul>

  <ul class="ctx-menu" id="ctxMenu" hidden role="menu" aria-label="Icon actions">
    <li role="none"><button role="menuitem" data-action="open-detail">Open Detail Page</button></li>
    <li role="none"><button role="menuitem" data-action="download-svg">Download SVG</button></li>
    <li class="ctx-menu-sep" role="separator"></li>
    <li role="none"><button role="menuitem" data-action="copy-svg">Copy SVG</button></li>
    <li role="none"><button role="menuitem" data-action="copy-name">Copy Name</button></li>
    <li role="none"><button role="menuitem" data-action="copy-component">Copy Component Name</button></li>
    <li role="none"><button role="menuitem" data-action="copy-import">Copy React Import</button></li>
  </ul>

  <div class="bottom-panel" id="bottomPanel" hidden>
    <div class="panel-header">
      <div class="panel-icon" id="panelIcon"></div>
      <div class="panel-info">
        <span class="panel-name" id="panelName"></span>
        <span class="panel-component" id="panelComponent"></span>
      </div>
      <div class="panel-header-actions">
        <a class="panel-header-btn" id="panelDetailLink" href="#">More Details</a>
        <button class="panel-close" id="panelClose" aria-label="Close panel">&times;</button>
      </div>
    </div>
    <div class="panel-tabs" role="tablist">
      <button class="panel-tab active" role="tab" data-tab="svg" aria-selected="true">SVG</button>
      <button class="panel-tab" role="tab" data-tab="react" aria-selected="false">React</button>
    </div>
    <div class="panel-content" id="panelContent"></div>
  </div>

  <script>
    const search = document.querySelector("#iconSearch");
    const items = Array.from(document.querySelectorAll(".icon-item")).filter((item) => item instanceof HTMLElement);

    search?.addEventListener("input", () => {
      if (!(search instanceof HTMLInputElement)) return;
      const query = search.value.trim().toLowerCase();
      for (const item of items) {
        const match = item.dataset.name?.toLowerCase().includes(query);
        item.hidden = !match;
      }
    });

    // Context menu
    const ctxMenu = document.getElementById("ctxMenu") as HTMLElement;
    let activeItem: HTMLElement | null = null;

    function hideMenu() {
      ctxMenu.hidden = true;
      activeItem = null;
    }

    document.addEventListener("scroll", hideMenu);
    window.addEventListener("resize", hideMenu);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        hideMenu();
        hidePanel();
      }
    });

    document.addEventListener("click", (e) => {
      if (!(e.target as HTMLElement).closest("#ctxMenu")) hideMenu();
    });

    document.getElementById("iconGrid")?.addEventListener("contextmenu", (e) => {
      const item = (e.target as HTMLElement).closest(".icon-item") as HTMLElement | null;
      if (!item) return;
      e.preventDefault();
      activeItem = item;

      const x = Math.min(e.clientX, window.innerWidth - 180);
      const y = Math.min(e.clientY, window.innerHeight - 240);
      ctxMenu.style.left = `${x}px`;
      ctxMenu.style.top = `${y}px`;
      ctxMenu.hidden = false;
    });

    ctxMenu.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("button");
      if (!btn || !activeItem) return;

      const action = btn.dataset.action;
      const svg = activeItem.dataset.svg || "";
      const name = (activeItem.dataset.name || "").split(" ")[0];
      const component = activeItem.dataset.component || "";

      switch (action) {
        case "copy-svg":
          navigator.clipboard.writeText(svg);
          break;
        case "copy-name":
          navigator.clipboard.writeText(name);
          break;
        case "copy-component":
          navigator.clipboard.writeText(component);
          break;
        case "copy-import":
          navigator.clipboard.writeText(`import { ${component} } from "vadivam-react";`);
          break;
        case "download-svg": {
          const blob = new Blob([svg], { type: "image/svg+xml" });
          const url = URL.createObjectURL(blob);
          const a = document.createElement("a");
          a.href = url;
          a.download = `${name}.svg`;
          a.click();
          URL.revokeObjectURL(url);
          break;
        }
        case "open-detail":
          window.location.href = `/icons/${name}/`;
          break;
      }

      hideMenu();
    });

    // Bottom panel
    const panel = document.getElementById("bottomPanel") as HTMLElement;
    const panelIcon = document.getElementById("panelIcon") as HTMLElement;
    const panelName = document.getElementById("panelName") as HTMLElement;
    const panelComponent = document.getElementById("panelComponent") as HTMLElement;
    const panelContent = document.getElementById("panelContent") as HTMLElement;
    const panelClose = document.getElementById("panelClose") as HTMLElement;
    const panelTabs = panel.querySelectorAll(".panel-tab");

    let panelSvg = "";
    let panelIconName = "";
    let panelComponentName = "";
    let currentTab = "svg";

    function showPanel(item: HTMLElement) {
      panelSvg = item.dataset.svg || "";
      panelIconName = (item.dataset.name || "").split(" ")[0];
      panelComponentName = item.dataset.component || "";

      panelIcon.innerHTML = panelSvg;
      panelName.textContent = panelIconName;
      panelComponent.textContent = panelComponentName;

      const detailLink = document.getElementById("panelDetailLink") as HTMLAnchorElement;
      detailLink.href = `/icons/${panelIconName}/`;

      setActiveTab("svg");
      panel.hidden = false;

      // highlight selected icon
      items.forEach((i) => i.classList.remove("icon-item-active"));
      item.classList.add("icon-item-active");
    }

    function hidePanel() {
      panel.hidden = true;
      items.forEach((i) => i.classList.remove("icon-item-active"));
    }

    function setActiveTab(tab: string) {
      currentTab = tab;
      panelTabs.forEach((t) => {
        const isActive = t.getAttribute("data-tab") === tab;
        t.classList.toggle("active", isActive);
        t.setAttribute("aria-selected", String(isActive));
      });
      renderTabContent();
    }

    function renderTabContent() {
      switch (currentTab) {
        case "svg":
          const singleLineSvg = panelSvg.replace(/\n\s*/g, "");
          panelContent.innerHTML = `
            <div class="panel-code-wrap">
              <pre><code>${highlightSvg(singleLineSvg)}</code></pre>
              <div class="panel-code-btns">
                <button class="panel-copy-btn" data-copy="svg">Copy</button>
                <button class="panel-copy-btn" data-download="svg">Download</button>
              </div>
            </div>`;
          break;
        case "react":
          const importStr = `import { ${panelComponentName} } from "vadivam-react";`;
          const usageStr = `<${panelComponentName} />`;
          panelContent.innerHTML = `
            <div class="panel-code-wrap">
              <pre><code><span class="tok-keyword">import</span> { <span class="tok-component">${panelComponentName}</span> } <span class="tok-keyword">from</span> <span class="tok-string">"vadivam-react"</span>;</code></pre>
              <button class="panel-copy-btn" data-copy="import">Copy Import</button>
            </div>
            <div class="panel-code-wrap">
              <pre><code>&lt;<span class="tok-component">${panelComponentName}</span> /&gt;</code></pre>
              <button class="panel-copy-btn" data-copy="usage">Copy Usage</button>
            </div>`;
          break;
      }
    }

    function escapeHtml(str: string) {
      return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }

    function highlightSvg(svg: string) {
      // Work on raw SVG, build highlighted HTML directly
      let html = "";
      let i = 0;
      while (i < svg.length) {
        if (svg[i] === "<") {
          // Find end of tag
          const end = svg.indexOf(">", i);
          if (end === -1) {
            html += escapeHtml(svg.slice(i));
            break;
          }
          const tag = svg.slice(i, end + 1);
          html += highlightTag(tag);
          i = end + 1;
        } else {
          // Text content between tags
          const next = svg.indexOf("<", i);
          const text = next === -1 ? svg.slice(i) : svg.slice(i, next);
          html += escapeHtml(text);
          i = next === -1 ? svg.length : next;
        }
      }
      return html;
    }

    function highlightTag(tag: string) {
      // Match opening/closing tag name
      const tagMatch = tag.match(/^<(\/?)\s*([a-zA-Z][a-zA-Z0-9-]*)/);
      if (!tagMatch) return escapeHtml(tag);

      const slash = tagMatch[1];
      const name = tagMatch[2];
      let rest = tag.slice(tagMatch[0].length);
      const selfClose = rest.endsWith("/>");
      if (selfClose) rest = rest.slice(0, -2);
      else rest = rest.slice(0, -1); // remove >

      let result = `&lt;${slash}<span class="tok-keyword">${name}</span>`;

      // Highlight attributes
      const attrRegex = /([a-zA-Z][a-zA-Z0-9-:]*)\s*=\s*"([^"]*)"/g;
      let attrMatch;
      let lastIndex = 0;
      while ((attrMatch = attrRegex.exec(rest)) !== null) {
        // Add any whitespace before this attr
        if (attrMatch.index > lastIndex) {
          result += escapeHtml(rest.slice(lastIndex, attrMatch.index));
        }
        result += `<span class="tok-package">${escapeHtml(attrMatch[1])}</span>=<span class="tok-string">&quot;${escapeHtml(attrMatch[2])}&quot;</span>`;
        lastIndex = attrMatch.index + attrMatch[0].length;
      }
      if (lastIndex < rest.length) {
        result += escapeHtml(rest.slice(lastIndex));
      }

      result += selfClose ? "/&gt;" : "&gt;";
      return result;
    }

    // Click on icon opens panel
    document.getElementById("iconGrid")?.addEventListener("click", (e) => {
      const link = (e.target as HTMLElement).closest(".icon-link") as HTMLElement | null;
      if (!link) return;
      e.preventDefault();
      const item = link.closest(".icon-item") as HTMLElement | null;
      if (item) showPanel(item);
    });

    panelClose.addEventListener("click", hidePanel);

    // Tab switching
    panel.querySelector(".panel-tabs")?.addEventListener("click", (e) => {
      const tab = (e.target as HTMLElement).closest(".panel-tab");
      if (!tab) return;
      const tabName = tab.getAttribute("data-tab");
      if (tabName) setActiveTab(tabName);
    });

    // Copy actions inside panel
    panelContent.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("button") as HTMLElement | null;
      if (!btn) return;

      const copyType = btn.dataset.copy;
      const downloadType = btn.dataset.download;

      if (copyType === "svg") {
        navigator.clipboard.writeText(panelSvg);
        btn.textContent = "Copied!";
        setTimeout(() => { btn.textContent = "Copy"; }, 1500);
      } else if (copyType === "import") {
        navigator.clipboard.writeText(`import { ${panelComponentName} } from "vadivam-react";`);
        btn.textContent = "Copied!";
        setTimeout(() => { btn.textContent = "Copy Import"; }, 1500);
      } else if (copyType === "usage") {
        navigator.clipboard.writeText(`<${panelComponentName} />`);
        btn.textContent = "Copied!";
        setTimeout(() => { btn.textContent = "Copy Usage"; }, 1500);
      } else if (downloadType === "svg") {
        const blob = new Blob([panelSvg], { type: "image/svg+xml" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `${panelIconName}.svg`;
        a.click();
        URL.revokeObjectURL(url);
      }
    });
  </script>
</BaseLayout>

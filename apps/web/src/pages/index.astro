---
import { icons } from "vadivam";
import CodeBlock from "../components/CodeBlock.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const githubUrl = "https://github.com/praveenjuge/vadivam";
const reactImport = 'import { Activity } from "vadivam-react";';
const installSnippet = "bun add vadivam vadivam-react\nnpm install vadivam vadivam-react\npnpm add vadivam vadivam-react";
const svgImport = 'import activity from "vadivam/icons/activity.svg";';
const dynamicImport = 'import { DynamicIcon, dynamicIconImports } from "vadivam-react";';
---

<BaseLayout title="Vadivam Icons">
  <main class="shell">
    <header class="page-header">
      <div class="brand-row">
        <a class="brand" href="/">Vadivam</a>
        <div class="header-actions">
          <a class="icon-button" href={githubUrl} aria-label="Vadivam on GitHub" title="GitHub">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.42-4.04-1.42-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.21.09 1.85 1.24 1.85 1.24 1.07 1.84 2.82 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.53.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.29-1.23 3.29-1.23.66 1.65.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.49 5.93.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 .5Z" />
            </svg>
          </a>
        </div>
      </div>
      <h1>Vadivam icons</h1>
      <p class="lede">24px outline SVGs and React components generated from one optimized source.</p>
    </header>

    <section class="docs" aria-label="Install and import snippets">
      <CodeBlock label="Install" code={installSnippet} language="sh" />
      <CodeBlock label="React" code={reactImport} />
      <CodeBlock label="Raw SVG" code={svgImport} />
      <CodeBlock label="Dynamic" code={dynamicImport} />
    </section>

    <div class="toolbar">
      <input class="search" id="iconSearch" type="search" placeholder="Search icons" aria-label="Search icons" />
      <span class="muted" id="resultCount">{icons.length} results</span>
    </div>

    <ul class="icon-grid" id="iconGrid">
      {
        icons.map((icon) => (
          <li class="icon-item" data-name={`${icon.name} ${icon.componentName}`}>
            <a class="icon-link" href={`/icons/${icon.name}/`} aria-label={icon.componentName} title={icon.componentName}>
              <span class="icon-preview" set:html={icon.svg}></span>
              <span class="icon-name">{icon.componentName}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>

  <script>
    const search = document.querySelector("#iconSearch");
    const items = Array.from(document.querySelectorAll(".icon-item")).filter((item) => item instanceof HTMLElement);
    const count = document.querySelector("#resultCount");

    search?.addEventListener("input", () => {
      if (!(search instanceof HTMLInputElement)) return;
      const query = search.value.trim().toLowerCase();
      let visible = 0;
      for (const item of items) {
        const match = item.dataset.name?.toLowerCase().includes(query);
        item.hidden = !match;
        if (match) visible += 1;
      }
      if (count) count.textContent = `${visible} results`;
    });

  </script>
</BaseLayout>

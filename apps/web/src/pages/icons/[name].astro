---
import { icons, iconsByName } from "vadivam";
import Brand from "../../components/Brand.astro";
import CodeBlock from "../../components/CodeBlock.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return icons.map((icon) => ({
    params: { name: icon.name },
    props: { icon }
  }));
}

const { icon } = Astro.props;
const rawSvg = iconsByName[icon.name].svg;
const bunInstall = "bun add vadivam vadivam-react";
const npmInstall = "npm install vadivam vadivam-react";
const pnpmInstall = "pnpm add vadivam vadivam-react";
const namedImport = `import { ${icon.componentName} } from "vadivam-react";`;
const subpathImport = `import ${icon.componentName} from "vadivam-react/${icon.name}";`;
const svgImport = `import icon from "vadivam/icons/${icon.fileName}";`;
---

<BaseLayout title={`${icon.componentName} - Vadivam`}>
  
  <section class="detail">
    <div class="detail-preview" set:html={rawSvg}></div>
    <div class="detail-content">
      <h1>{icon.componentName}</h1>
      <CodeBlock label="Install with bun" code={bunInstall} language="sh" />
      <CodeBlock label="Install with npm" code={npmInstall} language="sh" />
      <CodeBlock label="Install with pnpm" code={pnpmInstall} language="sh" />
      <CodeBlock label="Named import" code={namedImport} />
      <CodeBlock label="Per-icon import" code={subpathImport} />
      <CodeBlock label="Raw SVG path" code={svgImport} />
      <CodeBlock label="SVG markup" code={rawSvg} language="svg" />
    </div>
  </section>

  <script>
    document.addEventListener("click", async (event) => {
      const button = event.target instanceof HTMLElement ? event.target.closest("button.snippet-copy") : null;
      if (!(button instanceof HTMLButtonElement)) return;
      const text = button.dataset.copy;
      if (!text) return;
      await navigator.clipboard.writeText(text);
      const original = button.textContent;
      button.textContent = "Copied";
      window.setTimeout(() => {
        button.textContent = original;
      }, 1200);
    });
  </script>
</BaseLayout>

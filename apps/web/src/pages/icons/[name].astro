---
import { icons, iconsByName } from "vadivam";
import CodeBlock from "../../components/CodeBlock.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return icons.map((icon) => ({
    params: { name: icon.name },
    props: { icon }
  }));
}

const { icon } = Astro.props;
const githubUrl = "https://github.com/praveenjuge/vadivam";
const importSnippet = `import { ${icon.componentName} } from "vadivam-react";`;
const subpathSnippet = `import ${icon.componentName} from "vadivam-react/${icon.name}";`;
const svgSnippet = `import icon from "vadivam/icons/${icon.fileName}";`;
---

<BaseLayout title={`${icon.componentName} - Vadivam`}>
  <main class="shell">
    <header class="page-header">
      <div class="brand-row">
        <a class="brand" href="/">Vadivam</a>
        <div class="header-actions">
          <a class="icon-button" href={githubUrl} aria-label="Vadivam on GitHub" title="GitHub">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.42-4.04-1.42-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.21.09 1.85 1.24 1.85 1.24 1.07 1.84 2.82 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.53.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.29-1.23 3.29-1.23.66 1.65.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.49 5.93.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 .5Z" />
            </svg>
          </a>
        </div>
      </div>
      <h1>{icon.componentName}</h1>
      <p class="lede">Pixel-perfect, open-source, gorgeous icons for refined interfaces.</p>
    </header>

    <section class="detail">
      <div class="detail-preview" set:html={iconsByName[icon.name].svg}></div>
      <div class="detail-content">
        <div class="actions">
          <button type="button" data-copy-url={`/icons/${icon.fileName}`}>Copy SVG</button>
          <button type="button" data-copy={importSnippet}>Copy React import</button>
          <button type="button" data-copy={subpathSnippet}>Copy subpath import</button>
        </div>
        <CodeBlock label="Named import" code={importSnippet} />
        <CodeBlock label="Per-icon import" code={subpathSnippet} />
        <CodeBlock label="Raw SVG" code={svgSnippet} />
      </div>
    </section>
  </main>

  <script>
    document.addEventListener("click", async (event) => {
      const button = event.target instanceof HTMLElement ? event.target.closest("button") : null;
      if (!button) return;
      const url = button.dataset.copyUrl;
      const text = url ? await fetch(url).then((response) => response.text()) : button.dataset.copy;
      if (!text) return;
      await navigator.clipboard.writeText(text);
      const original = button.textContent;
      button.textContent = "Copied";
      window.setTimeout(() => {
        button.textContent = original;
      }, 1200);
    });
  </script>
</BaseLayout>

---
import Brand from '../components/Brand.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Pixel-perfect, open-source, gorgeous icons for refined interfaces." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0c0c0c" media="(prefers-color-scheme: dark)" />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: light dark;
        --bg: #fff;
        --ink: #111;
        --muted: #737373;
        --line: #e8e8e8;
        --soft: #f6f6f6;
        --accent: #111;
        --code-keyword: #8a3b12;
        --code-string: #25633f;
        --code-package: #295f8f;
        --code-component: #6f3a1d;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0c0c0c;
          --ink: #f4f4f4;
          --muted: #a3a3a3;
          --line: #242424;
          --soft: #161616;
          --accent: #f4f4f4;
          --code-keyword: #d89b72;
          --code-string: #88c9a4;
          --code-package: #8dbce8;
          --code-component: #d6a27f;
        }
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-width: 320px;
        background: var(--bg);
        color: var(--ink);
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        letter-spacing: 0;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button,
      input {
        font: inherit;
      }

      button {
        border: 0;
        border-radius: 0;
        background: transparent;
        color: var(--ink);
        cursor: pointer;
        padding: 0;
      }

      button:hover,
      button:focus-visible,
      a:focus-visible {
        outline: 1px solid var(--accent);
        outline-offset: 2px;
      }

      code,
      pre {
        font-family: "SF Mono", "Roboto Mono", ui-monospace, monospace;
      }

      .shell {
        width: min(960px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 24px 0 48px;
      }

      .page-header {
        display: grid;
        gap: 8px;
        padding-bottom: 10px;
      }

      .brand-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .header-actions {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        color: var(--ink);
      }

      .brand-logo {
        display: block;
        width: auto;
        height: 22px;
        fill: currentColor;
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .icon-button {
        display: grid;
        width: 28px;
        height: 28px;
        place-items: center;
        color: var(--muted);
      }

      .icon-button:hover {
        color: var(--ink);
      }

      .icon-button svg {
        width: 18px;
        height: 18px;
        fill: currentColor;
      }

      h1 {
        max-width: 760px;
        margin: 0;
        font-size: clamp(1.45rem, 2.4vw, 2.25rem);
        line-height: 1.08;
        letter-spacing: 0;
      }

      .lede {
        max-width: 680px;
        margin: 0;
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.5;
      }

      .muted {
        color: var(--muted);
      }

      .toolbar {
        display: grid;
        gap: 8px;
        margin: 18px 0;
      }

      .search {
        width: 100%;
        border: 1px solid var(--line);
        background: transparent;
        border-radius: 8px;
        color: var(--ink);
        padding: 0.78rem 0.9rem;
      }

      .search:focus {
        border-color: var(--accent);
        outline: 2px solid color-mix(in srgb, var(--accent), transparent 86%);
      }

      .docs {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin: 18px 0;
      }

      .links {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin: 18px 0;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        height: 32px;
        padding: 0 10px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--bg);
        color: var(--ink);
        font-size: 0.85rem;
        line-height: 1;
        white-space: nowrap;
        transition: background-color 0.15s ease, border-color 0.15s ease;
      }

      .btn:hover {
        background: var(--soft);
        border-color: var(--ink);
      }

      .btn-icon {
        display: inline-grid;
        width: 16px;
        height: 16px;
        place-items: center;
      }

      .btn-icon svg {
        width: 16px;
        height: 16px;
        fill: currentColor;
      }

      .snippet {
        min-width: 0;
      }

      .snippet > .snippet-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        margin-bottom: 6px;
      }

      .snippet-head > span {
        color: var(--muted);
        font-size: 0.74rem;
      }

      .snippet-copy {
        color: var(--muted);
        font-size: 0.72rem;
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      .snippet-copy:hover,
      .snippet-copy:focus-visible {
        color: var(--ink);
      }

      pre {
        overflow: auto;
        margin: 0;
        border-radius: 8px;
        background: var(--soft);
        padding: 0.75rem;
        font-size: 0.76rem;
        line-height: 1.5;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
      }

      .tok-keyword {
        color: var(--code-keyword);
      }

      .tok-string {
        color: var(--code-string);
      }

      .tok-package {
        color: var(--code-package);
      }

      .tok-component {
        color: var(--code-component);
      }

      .tok-operator {
        color: var(--muted);
      }

      .icon-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(72px, 1fr));
        gap: 8px;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .icon-item {
        display: grid;
        min-height: 72px;
      }

      .icon-item[hidden] {
        display: none;
      }

      .icon-link {
        display: grid;
        place-items: center;
        align-content: center;
        min-height: 72px;
        border-radius: 8px;
      }

      .icon-link:hover {
        background: var(--soft);
      }

      .icon-preview {
        display: grid;
        width: 32px;
        height: 32px;
        place-items: center;
        color: var(--ink);
      }

      .icon-preview svg {
        width: 34px;
        height: 34px;
      }

      .detail {
        display: grid;
        grid-template-columns: 132px minmax(0, 1fr);
        gap: 28px;
        margin-top: 20px;
      }

      .detail-preview {
        display: grid;
        aspect-ratio: 1;
        place-items: center;
        background: transparent;
      }

      .detail-preview svg {
        width: 72px;
        height: 72px;
      }

      .detail-content {
        display: grid;
        align-content: start;
        gap: 14px;
      }

      @media (max-width: 720px) {
        .shell {
          width: min(100vw - 40px, 1040px);
          padding-top: 24px;
        }

        .docs {
          grid-template-columns: 1fr;
        }

        .detail {
          grid-template-columns: 1fr;
        }

        .detail-preview {
          width: 132px;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <header class="page-header">
        <Brand />
        <p class="lede">Pixel-perfect, open-source, gorgeous icons for refined interfaces.</p>
      </header>

      <slot />
    </main>
  </body>
</html>

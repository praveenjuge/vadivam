---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "A clean outline icon set by Praveen Juge." } = Astro.props;
const favicon =
  "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Cpath d='M4 12h16M12 4v16' stroke='black' stroke-width='2' stroke-linecap='round'/%3E%3C/svg%3E";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={favicon} />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #fff;
        --ink: #111;
        --muted: #737373;
        --line: #e5e5e5;
        --soft: #f7f7f7;
        --accent: #111;
        --code-keyword: #8a3b12;
        --code-string: #25633f;
        --code-package: #295f8f;
        --code-component: #6f3a1d;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-width: 320px;
        background: var(--bg);
        color: var(--ink);
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        letter-spacing: 0;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button,
      input {
        font: inherit;
      }

      button {
        border: 0;
        border-radius: 0;
        background: transparent;
        color: var(--ink);
        cursor: pointer;
        padding: 0;
      }

      button:hover,
      button:focus-visible,
      a:focus-visible {
        outline: 1px solid var(--accent);
        outline-offset: 2px;
      }

      code,
      pre {
        font-family: "SF Mono", "Roboto Mono", ui-monospace, monospace;
      }

      .shell {
        width: min(1040px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 28px 0 56px;
      }

      .page-header {
        display: grid;
        gap: 10px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--line);
      }

      .brand-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .brand {
        font-size: 0.82rem;
        font-weight: 650;
        color: var(--muted);
      }

      h1 {
        max-width: 760px;
        margin: 0;
        font-size: clamp(1.45rem, 2.4vw, 2.25rem);
        line-height: 1.08;
        letter-spacing: 0;
      }

      .lede {
        max-width: 680px;
        margin: 0;
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.5;
      }

      .muted {
        color: var(--muted);
      }

      .toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin: 20px 0 14px;
      }

      .search {
        width: min(100%, 420px);
        border: 0;
        border-bottom: 1px solid var(--line);
        border-radius: 0;
        background: transparent;
        color: var(--ink);
        padding: 0.45rem 0;
      }

      .docs {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        margin: 18px 0 8px;
      }

      .snippet {
        min-width: 0;
        border-top: 1px solid var(--line);
        padding-top: 8px;
      }

      .snippet > span {
        display: block;
        margin-bottom: 6px;
        color: var(--muted);
        font-size: 0.74rem;
      }

      pre {
        overflow: auto;
        margin: 0;
        background: transparent;
        padding: 0;
        font-size: 0.76rem;
        line-height: 1.5;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
      }

      .tok-keyword {
        color: var(--code-keyword);
      }

      .tok-string {
        color: var(--code-string);
      }

      .tok-package {
        color: var(--code-package);
      }

      .tok-component {
        color: var(--code-component);
      }

      .tok-operator {
        color: var(--muted);
      }

      .icon-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 0;
        margin: 0;
        padding: 0;
        list-style: none;
        border-top: 1px solid var(--line);
        border-left: 1px solid var(--line);
      }

      .icon-item {
        display: grid;
        gap: 8px;
        padding: 10px;
        border-right: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .icon-link {
        display: grid;
        gap: 8px;
      }

      .icon-preview {
        display: grid;
        width: 32px;
        height: 32px;
        place-items: center;
        color: var(--ink);
      }

      .icon-preview svg {
        width: 24px;
        height: 24px;
      }

      .icon-name {
        display: grid;
        gap: 3px;
        min-width: 0;
      }

      .icon-name strong,
      .icon-name code {
        overflow: hidden;
        overflow-wrap: anywhere;
      }

      .icon-name code {
        color: var(--muted);
        font-size: 0.72rem;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .actions button {
        color: var(--muted);
        font-size: 0.72rem;
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      .detail {
        display: grid;
        grid-template-columns: 132px minmax(0, 1fr);
        gap: 28px;
        margin-top: 20px;
      }

      .detail-preview {
        display: grid;
        aspect-ratio: 1;
        place-items: center;
        background: transparent;
      }

      .detail-preview svg {
        width: 72px;
        height: 72px;
      }

      .detail-content {
        display: grid;
        align-content: start;
        gap: 14px;
      }

      @media (max-width: 720px) {
        .shell {
          width: min(100vw - 24px, 1040px);
          padding-top: 24px;
        }

        .brand-row,
        .toolbar {
          align-items: flex-start;
          flex-direction: column;
        }

        .docs {
          grid-template-columns: 1fr;
        }

        .detail {
          grid-template-columns: 1fr;
        }

        .detail-preview {
          width: 132px;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>

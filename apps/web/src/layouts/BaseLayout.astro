---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "A clean outline icon set by Praveen Juge." } = Astro.props;
const favicon =
  "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Cpath d='M4 12h16M12 4v16' stroke='black' stroke-width='2' stroke-linecap='round'/%3E%3C/svg%3E";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={favicon} />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f8f8f5;
        --ink: #111;
        --muted: #6d6a63;
        --line: #d9d6ce;
        --soft: #efede7;
        --accent: #006f5f;
        --code-keyword: #8f3f00;
        --code-string: #116143;
        --code-package: #075985;
        --code-component: #7c2d12;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-width: 320px;
        background: var(--bg);
        color: var(--ink);
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        letter-spacing: 0;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button,
      input {
        font: inherit;
      }

      button {
        border: 1px solid var(--line);
        border-radius: 0;
        background: transparent;
        color: var(--ink);
        cursor: pointer;
        padding: 0.48rem 0.62rem;
      }

      button:hover,
      button:focus-visible,
      a:focus-visible {
        border-color: var(--accent);
        outline: 2px solid color-mix(in srgb, var(--accent), transparent 72%);
        outline-offset: 2px;
      }

      code,
      pre {
        font-family: "SF Mono", "Roboto Mono", ui-monospace, monospace;
      }

      .shell {
        width: min(1080px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 32px 0 64px;
      }

      .page-header {
        display: grid;
        gap: 12px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--line);
      }

      .brand-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .brand {
        font-size: 0.86rem;
        font-weight: 650;
        color: var(--muted);
      }

      h1 {
        max-width: 760px;
        margin: 0;
        font-size: clamp(1.8rem, 3.2vw, 3.2rem);
        line-height: 1;
        letter-spacing: 0;
      }

      .lede {
        max-width: 680px;
        margin: 0;
        color: var(--muted);
        font-size: 0.96rem;
        line-height: 1.6;
      }

      .muted {
        color: var(--muted);
      }

      .toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin: 22px 0;
      }

      .search {
        width: min(100%, 420px);
        border: 1px solid var(--line);
        border-radius: 0;
        background: transparent;
        color: var(--ink);
        padding: 0.68rem 0.78rem;
      }

      .docs {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
        margin: 24px 0 8px;
      }

      .snippet {
        min-width: 0;
        border-top: 1px solid var(--line);
        padding-top: 12px;
      }

      .snippet > span {
        display: block;
        margin-bottom: 8px;
        color: var(--muted);
        font-size: 0.8rem;
      }

      pre {
        overflow: auto;
        margin: 0;
        background: var(--soft);
        padding: 12px;
        font-size: 0.82rem;
        line-height: 1.55;
      }

      .tok-keyword {
        color: var(--code-keyword);
      }

      .tok-string {
        color: var(--code-string);
      }

      .tok-package {
        color: var(--code-package);
      }

      .tok-component {
        color: var(--code-component);
      }

      .tok-operator {
        color: var(--muted);
      }

      .icon-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 1px;
        margin: 0;
        padding: 0;
        list-style: none;
        border: 1px solid var(--line);
        background: var(--line);
      }

      .icon-item {
        display: grid;
        gap: 10px;
        background: var(--bg);
        padding: 12px;
      }

      .icon-link {
        display: grid;
        gap: 12px;
      }

      .icon-preview {
        display: grid;
        width: 40px;
        height: 40px;
        place-items: center;
        color: var(--ink);
      }

      .icon-preview svg {
        width: 28px;
        height: 28px;
      }

      .icon-name {
        display: grid;
        gap: 3px;
        min-width: 0;
      }

      .icon-name strong,
      .icon-name code {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .icon-name code {
        color: var(--muted);
        font-size: 0.78rem;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }

      .actions button {
        padding: 0.45rem 0.55rem;
        font-size: 0.78rem;
      }

      .detail {
        display: grid;
        grid-template-columns: 180px minmax(0, 1fr);
        gap: 24px;
        margin-top: 24px;
      }

      .detail-preview {
        display: grid;
        aspect-ratio: 1;
        place-items: center;
        border: 1px solid var(--line);
        background: transparent;
      }

      .detail-preview svg {
        width: 88px;
        height: 88px;
      }

      .detail-content {
        display: grid;
        align-content: start;
        gap: 18px;
      }

      @media (max-width: 720px) {
        .shell {
          width: min(100vw - 24px, 1120px);
          padding-top: 28px;
        }

        .brand-row,
        .toolbar {
          align-items: flex-start;
          flex-direction: column;
        }

        .docs,
        .detail {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>

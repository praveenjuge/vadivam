{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "vadivam",
  "compatibility_date": "2026-05-16",
  "workers_dev": false,
  "preview_urls": false,
  "assets": {
    "directory": "./apps/web/dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "vadivam.praveenjuge.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
